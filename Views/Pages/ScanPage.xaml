<Page x:Class="SickReg.Desktop.Views.Pages.ScanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:SickReg.Desktop.ViewModels"
      d:DataContext="{d:DesignInstance vm:ScanViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Escanear"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Escanear Registro" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Analise profunda do registro do Windows" FontSize="14" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Scan Progress Area -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="500">

            <!-- Before scan -->
            <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource InverseBoolToVisConverter}}">
                <ui:SymbolIcon Symbol="Search24" FontSize="64" HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,24" />

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="16" HorizontalAlignment="Center" Opacity="0.7" Margin="0,0,0,24" />

                <ui:Button Content="Iniciar Scan"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Play24}"
                           FontSize="15"
                           Padding="28,14"
                           HorizontalAlignment="Center"
                           Command="{Binding StartScanCommand}"
                           Visibility="{Binding ScanCompleted, Converter={StaticResource InverseBoolToVisConverter}}" />

                <!-- Post-scan actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="{Binding ScanCompleted, Converter={StaticResource BoolToVisConverter}}">
                    <ui:Button Content="Novo Scan"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Margin="0,0,12,0"
                               Command="{Binding StartScanCommand}" />
                    <ui:Button Content="Ver Resultados"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon DocumentBulletList24}"
                               Command="{Binding ViewResultsCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- During scan -->
            <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="120" Height="120"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,24" />

                <TextBlock Text="{Binding CurrentCategory}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="14" Opacity="0.6"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />

                <TextBlock FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Run Text="Problemas encontrados: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Run Text="{Binding IssuesFound, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>

                <ProgressBar Value="{Binding ProgressPercentage}" Height="4" Margin="0,0,0,24" />

                <ui:Button Content="Cancelar"
                           Appearance="Danger"
                           Icon="{ui:SymbolIcon Dismiss24}"
                           HorizontalAlignment="Center"
                           Command="{Binding CancelScanCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
