<Page x:Class="SickReg.Desktop.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:SickReg.Desktop.ViewModels"
      d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Dashboard"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="SickReg" FontSize="36" FontWeight="Bold" />
            <TextBlock Text="Limpeza Inteligente de Registro do Windows" FontSize="16" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Admin Warning -->
        <ui:InfoBar Grid.Row="1"
                    Title="Modo Limitado"
                    Message="Execute como Administrador para limpeza completa do registro."
                    Severity="Warning"
                    IsOpen="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}"
                    IsClosable="False"
                    Margin="0,0,0,20" />

        <!-- Stats Cards -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,32">
            <ui:CardControl Margin="0,0,12,0">
                <ui:CardControl.Header>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Ultimo Scan" FontSize="13" Opacity="0.6" />
                            <TextBlock Text="{Binding LastScanDate}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:SymbolIcon Symbol="Clock24" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.4" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <ui:CardControl Margin="6,0">
                <ui:CardControl.Header>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Problemas Encontrados" FontSize="13" Opacity="0.6" />
                            <TextBlock Text="{Binding LastScanIssues}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:SymbolIcon Symbol="Warning24" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.4" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

            <ui:CardControl Margin="12,0,0,0">
                <ui:CardControl.Header>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Backups Salvos" FontSize="13" Opacity="0.6" />
                            <TextBlock Text="{Binding BackupCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="28" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.4" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>
        </UniformGrid>

        <!-- Quick Actions -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:Button Content="Iniciar Scan Completo"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Search24}"
                       FontSize="16"
                       Padding="32,16"
                       HorizontalAlignment="Center"
                       Command="{Binding StartScanCommand}" />
            <TextBlock Text="Escaneia profundamente o registro em busca de problemas"
                       FontSize="13" Opacity="0.5" HorizontalAlignment="Center" Margin="0,12,0,0" />

            <ui:Button Content="Ver Backups"
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowDownload24}"
                       Margin="0,24,0,0"
                       HorizontalAlignment="Center"
                       Command="{Binding GoToBackupsCommand}" />
        </StackPanel>
    </Grid>
</Page>
